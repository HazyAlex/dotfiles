{
    /// Extensions
    //
    /// Movement:
    // Neo Vim
    // Hungry Delete
    // TabOut
    // Center Editor Window (SCROLLING in Neovim)
    // Macros               (SCROLLING in Neovim)
    //
    /// Themes/Customization:
    // Customize UI
    // Highlight
    // Yi light
    // Anirak
    // Slime
    //
    /// Language specific:
    //
    // (C++)       c/c++
    // (RUST)      ra-lsp
    // (Qt/Python) Python + Qt for Python + Pyright + Python Indent + Visual Studio Intellisense
    // (HASKELL)   Haskelly, Haskell Syntax Highlighting
    // (Markdown)  Markdown preview enhanced
    //
    // ----
    //  RA
    // ----
    "rust-analyzer.enableCargoWatchOnStartup": "enabled",
    "rust-analyzer.enableEnhancedTyping": false,
    "rust-analyzer.displayInlayHints": false,
    "rust-analyzer.cargo-watch.command": "clippy",
    "rust-analyzer.featureFlags": {
         // Automatically insert `()` and `<>` when completing functions and types.
         "completion.insertion.add-call-parenthesis": true,
         // Enable completions like `.if`, `.match`, etc.
         "completion.enable-postfix": true,
         // Show notification when workspace is fully loaded
         "notifications.workspace-loaded": false
    },
    // -------------
    //  Python (Qt)
    // -------------
    "qtForPython.path.designer": "C:\\Qt\\5.14.2\\mingw73_64\\bin\\designer.exe",
    "qtForPython.path.pyrcc": "pyside2-rcc.exe -o \"${fileBasenameNoExtension}_rc.py\"",
    "qtForPython.path.pyuic": "pyside2-uic.exe -o \"${fileDirname}\\ui_${fileBasenameNoExtension}.py\"",
    "python.experiments.enabled": false,
    "vsintellicode.python.completionsEnabled": true,
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "python.jediEnabled": false,
    // ---------------------------
    //  Telemetry && Auto-updates
    // ---------------------------
    "workbench.settings.enableNaturalLanguageSearch": false,
    "workbench.enableExperiments": false,
    "extensions.autoUpdate": false,
    "extensions.autoCheckUpdates": false,
    "update.mode": "manual",
    "update.showReleaseNotes": false,
    "telemetry.enableCrashReporter": false,
    "npm.fetchOnlinePackageInfo": false,
    // ----------
    //  Terminal
    // ----------
    "terminal.integrated.shell.windows": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
    "terminal.integrated.drawBoldTextInBrightColors": false,
    "terminal.integrated.rendererType": "canvas",
    "terminal.integrated.cursorStyle": "block",
    "terminal.integrated.fontSize": 16,
    "terminal.fontFamily": "Fira Mono Retina",
    "terminal.integrated.fontFamily": "monospace",
    "terminal.integrated.fontWeight": "200",
    "terminal.integrated.fontWeightBold": "400",
    // --------
    //  Window
    // --------
    "window.restoreWindows": "all",
    "window.menuBarVisibility": "toggle",
    "window.zoomLevel": 0,
    "window.titleBarStyle": "custom",
    "window.title": "${dirty}${activeEditorMedium}${separator}${rootName}${separator}",
    "window.enableMenuBarMnemonics": false,
    // -----------
    //  Workbench
    // -----------
    "workbench.startupEditor": "none",
    "workbench.editor.tabSizing": "shrink",
    "workbench.panel.defaultLocation": "right",
    "workbench.statusBar.visible": true,
    "workbench.activityBar.visible": false,
    "workbench.settings.editor": "json",
    "workbench.settings.useSplitJSON": false,
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.colorTheme": "Slime",
    "workbench.colorCustomizations": {
        "[Tokyo Night Storm]": {
            "terminal.ansiBrightBlack": "#da0000"
        },
    },
    // ----------
    //  Explorer
    // ----------
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/*/**": true,
        "vendor": true,
        "**/dist": true,
        "**/target/**": true
    },
    "breadcrumbs.enabled": true,
    "search.quickOpen.history.filterSortOrder": "recency",
    //"editor.definitionLinkOpensInPeek": "true",
    // --------
    //  Editor
    // --------
    "editor.cursorBlinking": "solid",
    "editor.cursorStyle": "block",
    "editor.formatOnSave": true,
    "editor.multiCursorPaste": "spread",
    "editor.snippetSuggestions": "top",
    "editor.suggestSelection": "first",
    "editor.folding": true,
    "editor.scrollBeyondLastLine": true,
    "editor.codeLens": true,
    "editor.lightbulb.enabled": false,
    "editor.minimap.enabled": false,
    "editor.fontFamily": "Fira Code Retina",
    "editor.fontSize": 16,
    "editor.fontLigatures": true,
    "editor.tokenColorCustomizations": {
        "[Yi Light]": {
            "comments": "#be2020"
        },
        "[Tokyo Night Storm]": {
            "comments": "#b5dbe8"
        }
    },
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.verticalScrollbarSize": 0,
    // -------------
    //  CustomizeUI
    // -------------
    "customizeUI.font.monospace": "Fira Code Retina",
    "customizeUI.font.regular": "Fira Code Retina",
    "customizeUI.fontSizeMap": {
        "13px": "14px",
        "monospace": "14px"
    },
    "customizeUI.stylesheet": {
        ".tabs-container .tab": "height: 40px !important",
        ".tabs": "height: 35px !important",
        "[aria-label='Editor actions']": "display: none !important;"
    },
    // --------
    //  NeoVim
    // --------
    "editor.lineNumbers": "relative",
    "vscode-neovim.neovimPath": "C:\\Program Files\\Neovim\\bin\\nvim.exe",
    "vscode-neovim.neovimInitPath": "C:\\Users\\Alex\\AppData\\Local\\nvim\\init.vim",
    "vscode-neovim.useCtrlKeysForInsertMode": true, // TODO: ?
    "vscode-neovim.mouseSelectionStartVisualMode": true,
    // -------
    //  C/C++
    // -------
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.clang_format_fallbackStyle": "{BasedOnStyle: WebKit, UseTab: Never, IndentWidth: 4}",
    "C_Cpp.enhancedColorization": "Enabled",
    "C_Cpp.suggestSnippets": false,
    // -----------
    //  Scrolling
    // -----------
    //
    // The "Neovim" extension leaves the scrolling up
    //  to VSCodium but it's awful so I replaced it.
    // (Needed extensions: macros, center-editor-window)
    //
    "macros.list": {
        "scrollDownAndCenter": [
            {
                "command": "cursorMove",
                "args": {
                    "to": "down",
                    "by": "line",
                    "value": 20,
                    "revealCursor": true
                }
            },
            "center-editor-window.center"
        ],
        "scrollUpAndCenter": [
            {
                "command": "cursorMove",
                "args": {
                    "to": "up",
                    "by": "line",
                    "value": 20,
                    "revealCursor": true
                }
            },
            "center-editor-window.center"
        ]
    },
    // -----------
    //  Highlight
    // -----------
    "highlight.regexes": {
        "(// ?TODO:?)(.*)": [
            {
                "overviewRulerColor": "#ddcc00",
                "backgroundColor": "#ddcc00",
                "color": "#1f1f1f",
                "fontWeight": "bold"
            },
            {
                "backgroundColor": "#ddcc00",
                "color": "#1f1f1f"
            }
        ],
        "(// ?FIXME:?)(.*)": [
            {
                "overviewRulerColor": "#dd0000",
                "backgroundColor": "#dd0000",
                "color": "#1f1f1f",
                "fontWeight": "bold"
            },
            {
                "backgroundColor": "#dd0000",
                "color": "#1f1f1f"
            }
        ],
        "(// )(@\\w+)": [
            {},
            {
                "color": "#4de0ff"
            }
        ]
    },
    "markdown-preview-enhanced.codeBlockTheme": "github.css",
    "markdown-preview-enhanced.usePandocParser": true
}
